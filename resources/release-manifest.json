{
  "schema_version": "1.0",
  "platform": {
    "initial_target": "windows-x64",
    "future_platforms": ["macos", "linux"]
  },
  "code_signing": {
    "signed": false,
    "risk": "Unsigned installers may trigger Windows SmartScreen warnings.",
    "mitigation": "Distribution instructions must explain how to proceed past the SmartScreen warning (More info -> Run anyway)."
  },
  "auto_update": {
    "enabled": false,
    "policy": "Users must manually download and reinstall new releases."
  },
  "user_data": {
    "stored_in_install_directory": false,
    "deleted_on_uninstall": false
  },
