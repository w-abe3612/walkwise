    { "name": "pypdf", "license": "BSD-3-Clause", "bundled": false },
    { "name": "Pillow", "license": "MIT-CMU", "bundled": false },
    { "name": "VOICEVOX Engine", "license": "See VOICEVOX terms of use", "bundled": false },
