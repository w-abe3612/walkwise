# Walkwise 環境変数テンプレート
#
# このfileを `.env` としてcopyし、必要な値を設定する。`.env`自体は.gitignore/.dockerignoreで
# 除外されるため、実際の秘密情報(APIキー等)がcommitやDocker build contextへ含まれることはない。
# 通常のtest実行(`python -m pytest`、normalマーカー)はこれらの変数を一切必要としない。

# --- Gemini(外部AI、integration_smoke/liveでのみ使用) ---
GEMINI_API_KEY=
GEMINI_API_VERSION=
GEMINI_MODEL=
GEMINI_MAX_RETRIES=
GEMINI_RETRY_WAIT_SEC=
GEMINI_MAX_RETRY_WAIT_SEC=

# --- 外部runtime(host実行時のみ、Docker通常テストでは未設定のままでよい) ---
VOICEVOX_URL=
TESSERACT_CMD=
FFMPEG_PATH=
FFPROBE_PATH=

# --- Electron/Worker連携 ---
WALKWISE_PYTHON_EXECUTABLE=
WALKWISE_DATA_ROOT=
WALKWISE_DB_PATH=
WALKWISE_LOG_LEVEL=

# --- ASR(音声認識、integration_smoke/liveでのみ使用) ---
WALKWISE_ASR_ENABLED=
WALKWISE_ASR_COMMAND=

# --- opt-inテストgate(docs/commands/external-connectivity.md参照) ---
WALKWISE_RUN_INTEGRATION_SMOKE=0
WALKWISE_RUN_INTEGRATION_LIVE=0
WALKWISE_RUN_PERFORMANCE=0
WALKWISE_RUN_RESILIENCE=0
